#【normal.config-01】
# 正常模式配置 - 完整功能配置

# 网络加速 - 由脚本根据源码类型动态添加
# UPnP 自动端口转发
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_miniupnpd=y

# FTP 服务器
CONFIG_PACKAGE_vsftpd=y
CONFIG_PACKAGE_luci-app-vsftpd=y

# ARP 绑定
CONFIG_PACKAGE_luci-app-arpbind=y

# CPU 限制
CONFIG_PACKAGE_luci-app-cpulimit=y

# ksmbd 文件共享
CONFIG_PACKAGE_kmod-fs-ksmbd=y
CONFIG_PACKAGE_ksmbd-tools=y
CONFIG_PACKAGE_luci-app-ksmbd=y
CONFIG_PACKAGE_luci-i18n-ksmbd-zh-cn=y

# samba4 已禁用
# CONFIG_PACKAGE_samba4-server is not set
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_wsdd2 is not set
# CONFIG_PACKAGE_luci-i18n-samba4-zh-cn is not set

# pppoe 相关（LEDE 源码有问题，在设备特殊规则中禁用）
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set

# 微信推送（LEDE 源码有问题，在设备特殊规则中禁用）
# CONFIG_PACKAGE_luci-app-wechatpush is not set
# CONFIG_PACKAGE_luci-i18n-wechatpush-zh-cn is not set

# DDNS 相关（全局禁用，因为所有源码编译都有问题）
# CONFIG_PACKAGE_ddns-scripts is not set
# CONFIG_PACKAGE_ddns-scripts_aliyun is not set
# CONFIG_PACKAGE_ddns-scripts_dnspod is not set
# CONFIG_PACKAGE_luci-app-ddns is not set

# 流量控制 (SQM)
CONFIG_PACKAGE_sqm-scripts=y
CONFIG_PACKAGE_luci-app-sqm=y

# 硬盘休眠
CONFIG_PACKAGE_luci-app-hd-idle=y

# 磁盘管理
CONFIG_PACKAGE_luci-app-diskman=y

# 家长控制/上网时间控制
CONFIG_PACKAGE_luci-app-accesscontrol=y

# KMS 激活服务
CONFIG_PACKAGE_vlmcsd=y
CONFIG_PACKAGE_luci-app-vlmcsd=y

# SmartDNS 智能DNS
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_luci-app-smartdns=y

# 语言包
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-i18n-vsftpd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-arpbind-zh-cn=y
CONFIG_PACKAGE_luci-i18n-cpulimit-zh-cn=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
CONFIG_PACKAGE_luci-i18n-hd-idle-zh-cn=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y
CONFIG_PACKAGE_luci-i18n-accesscontrol-zh-cn=y
CONFIG_PACKAGE_luci-i18n-vlmcsd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ksmbd-zh-cn=y

# ============================================
# LEDE 源码专用：禁用 luci-light 和 luci-proto-ppp
# 避免 ppp 依赖问题
# ============================================
# CONFIG_PACKAGE_luci-light is not set
# CONFIG_PACKAGE_luci-proto-ppp is not set

# 注意：Luci 基础组件保留
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# 注意：以下插件在 LEDE master 分支可能有编译问题，如需要请手动取消注释
# CONFIG_PACKAGE_luci-app-wechatpush is not set
# CONFIG_PACKAGE_ddns-scripts is not set
# CONFIG_PACKAGE_ddns-scripts_aliyun is not set
# CONFIG_PACKAGE_ddns-scripts_dnspod is not set
# CONFIG_PACKAGE_luci-app-ddns is not set
#【normal.config-01-end】
