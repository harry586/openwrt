#【base.config-01】
# 基础模式配置 - 最小化配置，用于测试编译
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y

# === 核心包 ===
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_fstools=y
CONFIG_PACKAGE_libc=y
CONFIG_PACKAGE_libgcc=y
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_ubox=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_ubusd=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_usign=y

# === DNSMASQ：只启用普通版，禁用 full 版避免冲突 ===
CONFIG_PACKAGE_dnsmasq=y
# CONFIG_PACKAGE_dnsmasq-full is not set

# === 禁用 DDNS 所有相关包（base 模式不需要）===
# CONFIG_PACKAGE_ddns-scripts is not set
# CONFIG_PACKAGE_ddns-scripts_aliyun is not set
# CONFIG_PACKAGE_ddns-scripts_dnspod is not set
# CONFIG_PACKAGE_luci-app-ddns is not set

# === 禁用 PPPoE（base 模式不需要，避免安装失败）===
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set

# === 解决 luci-light 依赖问题：安装 luci-proto-ppp ===
CONFIG_PACKAGE_luci-proto-ppp=y

# === Luci 界面（保留用于测试）===
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# === 无线驱动 ===
CONFIG_PACKAGE_wpad-basic-wolfssl=y

# === iptables ===
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_iptables-mod-conntrack-extra=y
CONFIG_PACKAGE_iptables-mod-ipopt=y
CONFIG_PACKAGE_iptables-mod-extra=y
# CONFIG_PACKAGE_ip6tables is not set
# CONFIG_PACKAGE_kmod-ipt-nat6 is not set
CONFIG_PACKAGE_kmod-ipt-extra=y

# === 常用网络插件 ===
CONFIG_PACKAGE_bridge=y
CONFIG_PACKAGE_blockd=y
CONFIG_PACKAGE_reset-button=y
CONFIG_PACKAGE_uhttpd=y

# === 基本工具 ===
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_bash=y

# === 必须的内核模块 ===
CONFIG_PACKAGE_kmod-nf-conntrack=y
# CONFIG_PACKAGE_kmod-nf-conntrack6 is not set
CONFIG_PACKAGE_kmod-nf-nat=y
# CONFIG_PACKAGE_kmod-nf-nat6 is not set
CONFIG_PACKAGE_kmod-crypto-crc32c=y

# === 禁用 IPv6（base 模式保持精简）===
CONFIG_IPV6=n
# CONFIG_PACKAGE_kmod-ipv6 is not set
# CONFIG_PACKAGE_kmod-ip6tables is not set
# CONFIG_PACKAGE_odhcp6c is not set
# CONFIG_PACKAGE_odhcpd is not set
#【base.config-01-end】
